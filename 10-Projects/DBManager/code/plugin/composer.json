{
    "name": "dbmanager/client",
    "description": "DBManager WordPress client plugin",
    "type": "wordpress-plugin",
    "require": { "php": ">=8.2",
        "maxmind-db/reader": "^1.13" },
    "require-dev": { "phpunit/phpunit": "^11.0" },
    "autoload": { "psr-4": { "DBM\\": "dbmanager/src/" } },
    "autoload-dev": { "psr-4": { "DBM\\Tests\\": "tests/" } },
    "config": { "optimize-autoloader": true }
}
